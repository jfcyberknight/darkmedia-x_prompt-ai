# =============================================================================
# Variables d'environnement du conteneur (docker compose --env-file .env.docker)
# Copier ce fichier en .env.docker puis renseigner les valeurs.
#
# ⚙️  SECRETS VIA DOPPLER (recommandé) : renseignez uniquement DOPPLER_TOKEN
#     ci-dessous. Le SMTP (MAIL_*) et les clés IA (*_API_KEY) sont alors
#     injectés au démarrage depuis votre Doppler — même source que tous vos
#     autres projets, aucun secret écrit dans ce fichier. Les blocs MAIL_* et
#     clés IA plus bas ne servent que si vous n'utilisez PAS Doppler.
# =============================================================================

APP_NAME="DarkMedia Prompt AI"
APP_ENV=production
APP_DEBUG=false
# URL publique de l'app (derrière votre reverse-proxy TLS)
APP_URL=https://prompts.mondomaine.fr
APP_LOCALE=fr

# Clé d'application : `docker run --rm darkmedia/prompt-ai php artisan key:generate --show`
# Si laissée vide (et absente de Doppler), une clé est générée au premier
# démarrage et persistée dans le volume /data.
APP_KEY=

# ---- Doppler (gestionnaire de secrets) ----
# Service Token Doppler lié au projet/config de cette app (dashboard Doppler →
# Access → Service Tokens). Le token porte déjà le projet et l'environnement :
# rien d'autre à préciser. Les secrets qu'il expose (MAIL_*, *_API_KEY…) sont
# injectés au runtime et priment sur les valeurs de ce fichier.
# Renseignez votre Service Token (préfixe « dp.st. ») ci-dessous :
DOPPLER_TOKEN=

# ---- Base de données ----
# SQLite (défaut, zéro dépendance — le fichier vit dans le volume /data).
DB_CONNECTION=sqlite
DB_DATABASE=/data/database.sqlite
# Pour MySQL/PostgreSQL externe, remplacer par :
# DB_CONNECTION=mysql
# DB_HOST=db.mondomaine.fr
# DB_PORT=3306
# DB_DATABASE=promptai
# DB_USERNAME=promptai
# DB_PASSWORD=changeme

# ---- Authentification par magic link ----
# Adresses autorisées à se connecter (compte créé automatiquement).
MAGIC_LINK_ALLOWED_EMAILS=vous@mondomaine.fr
MAGIC_LINK_EXPIRATION_MINUTES=15

# ---- Emails (SMTP) ----
# Fournis par Doppler (MAIL_MAILER, MAIL_HOST, MAIL_PORT, MAIL_USERNAME,
# MAIL_PASSWORD, MAIL_SCHEME, MAIL_FROM_ADDRESS, MAIL_FROM_NAME).
# Décommentez ci-dessous UNIQUEMENT si vous n'utilisez pas Doppler :
# MAIL_MAILER=smtp
# MAIL_HOST=smtp.mondomaine.fr
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_SCHEME=tls
# MAIL_FROM_ADDRESS="prompt-ai@mondomaine.fr"
# MAIL_FROM_NAME="DarkMedia Prompt AI"

# ---- IA (OpenRouter) ----
# OPENROUTER_API_KEY et OPENROUTER_API_URL sont fournis par Doppler.
# Provider par défaut du serveur (le front peut en choisir un autre) :
AI_DEFAULT_PROVIDER=openrouter
AI_TIMEOUT_SECONDS=45
# Décommentez UNIQUEMENT si vous n'utilisez pas Doppler :
# OPENROUTER_API_KEY=
# OPENROUTER_API_URL=https://openrouter.ai/api/v1

# Port exposé sur l'hôte (mappé vers 8080 dans le conteneur)
APP_PORT=8080

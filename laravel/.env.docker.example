# =============================================================================
# Variables d'environnement du conteneur (docker compose --env-file .env.docker)
# Copier ce fichier en .env.docker puis renseigner les valeurs.
# =============================================================================

APP_NAME="DarkMedia Prompt AI"
APP_ENV=production
APP_DEBUG=false
# URL publique de l'app (derrière votre reverse-proxy TLS)
APP_URL=https://prompts.mondomaine.fr
APP_LOCALE=fr

# Clé d'application : `docker run --rm darkmedia/prompt-ai php artisan key:generate --show`
# Si laissée vide, une clé est générée au premier démarrage et persistée dans le volume.
APP_KEY=

# ---- Base de données ----
# SQLite (défaut, zéro dépendance — le fichier vit dans le volume /data).
DB_CONNECTION=sqlite
DB_DATABASE=/data/database.sqlite
# Pour MySQL/PostgreSQL externe, remplacer par :
# DB_CONNECTION=mysql
# DB_HOST=db.mondomaine.fr
# DB_PORT=3306
# DB_DATABASE=promptai
# DB_USERNAME=promptai
# DB_PASSWORD=changeme

# ---- Emails (obligatoire pour recevoir les magic links) ----
MAIL_MAILER=smtp
MAIL_HOST=smtp.mondomaine.fr
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=null
MAIL_FROM_ADDRESS="prompt-ai@mondomaine.fr"
MAIL_FROM_NAME="DarkMedia Prompt AI"

# ---- Authentification par magic link ----
# Adresses autorisées à se connecter (compte créé automatiquement).
MAGIC_LINK_ALLOWED_EMAILS=vous@mondomaine.fr
MAGIC_LINK_EXPIRATION_MINUTES=15

# ---- Clés des providers IA (au moins une pour activer les fonctions IA) ----
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://api.openai.com/v1
OPENROUTER_API_KEY=
AI_TIMEOUT_SECONDS=45

# Port exposé sur l'hôte (mappé vers 8080 dans le conteneur)
APP_PORT=8080

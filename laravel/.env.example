APP_NAME="DarkMedia Prompt AI"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_LOCALE=fr
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# SQLite par défaut (zéro dépendance). Pour MySQL/PostgreSQL sur le VPS,
# renseigner DB_CONNECTION=mysql|pgsql et les variables DB_* ci-dessous.
DB_CONNECTION=sqlite
# DB_DATABASE=/data/database.sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=promptai
# DB_USERNAME=promptai
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ---- Envoi des magic links ----
# En local : MAIL_MAILER=log (le lien apparaît dans storage/logs/laravel.log).
# En production (VPS) : MAIL_MAILER=dmxmailer → envoi via le service e-mail privé
# du VPS (dmx-mailer), aucun SMTP local. Voir DMX_MAILER_* et .env.vps.example.
MAIL_MAILER=log
MAIL_FROM_ADDRESS="prompt-ai@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Service e-mail privé du VPS (dmx-mailer). Requis quand MAIL_MAILER=dmxmailer.
# En local avec MAIL_MAILER=log, laisser vide.
DMX_MAILER_URL=http://dmx-mailer:8080
DMX_MAILER_KEY=

# ---- Authentification par magic link ----
# Adresses autorisées à se connecter (séparées par des virgules). Un compte est
# créé automatiquement à la première connexion. Liste vide = seuls les comptes
# déjà en base peuvent se connecter.
MAGIC_LINK_ALLOWED_EMAILS=
MAGIC_LINK_EXPIRATION_MINUTES=15

# ---- Proxy IA (clés côté serveur, jamais exposées au navigateur) ----
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://api.openai.com/v1
OPENROUTER_API_KEY=
OPENROUTER_API_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=deepseek/deepseek-chat-v3-0324
# Provider IA par défaut (le front peut en choisir un autre dans les Paramètres).
AI_DEFAULT_PROVIDER=openrouter
AI_TIMEOUT_SECONDS=45

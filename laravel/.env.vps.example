# =============================================================================
# .env.vps.example -- variables pour le deploiement VPS (Cloudflare Tunnel).
# Copier en .env DANS CE DOSSIER (laravel/) puis renseigner les valeurs :
#   cp .env.vps.example .env
#
# NB : CLOUDFLARE_TUNNEL_TOKEN, COMPOSE_PROFILES et APP_URL sont (re)ecrits
# automatiquement par ../scripts/setup-cloudflare-tunnel.sh lors du deploiement
# -- inutile de les renseigner a la main.
# =============================================================================

APP_NAME="DarkMedia Prompt AI"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://promptai.darkmedia-x.com
APP_LOCALE=fr

# Laisse vide : genere et persiste dans le volume /data au 1er demarrage.
APP_KEY=

# ---- Base de donnees : SQLite dans le volume /data ----
DB_CONNECTION=sqlite
DB_DATABASE=/data/database.sqlite

# ---- Emails (obligatoire pour recevoir les magic links) ----
MAIL_MAILER=smtp
MAIL_HOST=smtp.exemple.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
# smtp (STARTTLS/587) ou smtps (TLS/465) -- jamais "tls".
MAIL_SCHEME=null
MAIL_FROM_ADDRESS="prompt-ai@darkmedia-x.com"
MAIL_FROM_NAME="DarkMedia Prompt AI"

# ---- Authentification par magic link ----
# Adresses autorisees (compte cree automatiquement a la 1re connexion).
MAGIC_LINK_ALLOWED_EMAILS=vallee.jeanfrancois@gmail.com
MAGIC_LINK_EXPIRATION_MINUTES=15

# ---- Cles des providers IA (au moins une pour activer les fonctions IA) ----
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
DEEPSEEK_API_KEY=
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://api.openai.com/v1
OPENROUTER_API_KEY=
AI_TIMEOUT_SECONDS=45

# ---- Reseau VPS ----
# Port loopback de diagnostic sur l'hote (mappe vers 8080 dans le conteneur).
APP_PORT=8092

# --- Ecrits automatiquement par setup-cloudflare-tunnel.sh (ne pas remplir) ---
# COMPOSE_PROFILES=tunnel
# CLOUDFLARE_TUNNEL_TOKEN=
